#!/usr/bin/env bash
# zjctl — JSON-first CLI wrapper around zellij action for AI agents
set -euo pipefail

ZJCTL_DIR="$(cd "$(dirname "$0")" && pwd)"

# Source library modules
source "$ZJCTL_DIR/lib/error.sh"
source "$ZJCTL_DIR/lib/output.sh"
source "$ZJCTL_DIR/lib/safety.sh"
source "$ZJCTL_DIR/lib/identity.sh"

# --- Global flag defaults ---
ZJCTL_FORMAT="json"
ZJCTL_DRY_RUN="false"
ZJCTL_NO_GUARD="false"
ZJCTL_SESSION=""

# --- Argument parsing ---
# Parse global flags before the resource noun; once we see a non-flag arg,
# everything after is passed through to the subcommand.
ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --format|-f)
            ZJCTL_FORMAT="$2"; shift 2 ;;
        --dry-run|-n)
            ZJCTL_DRY_RUN="true"; shift ;;
        --quiet|-q)
            ZJCTL_FORMAT="quiet"; shift ;;
        --session|-s)
            ZJCTL_SESSION="$2"; shift 2 ;;
        --no-guard)
            ZJCTL_NO_GUARD="true"; shift ;;
        --help|-h)
            echo "Usage: zjctl [--format json|table|quiet] [--dry-run] [--quiet] [--session NAME] [--no-guard] <command>"
            echo ""
            echo "Commands:"
            echo "  sessions list"
            echo "  tabs     list | focus <tab> | open [--name NAME]"
            echo "  panes    list [--tab TAB] | read <pane> | write <pane> <text>"
            echo "           send-keys <pane> <keys...> | focus <pane> | open [flags]"
            exit 0
            ;;
        -*)
            # Before seeing a resource noun, unknown flags are errors
            if [ ${#ARGS[@]} -eq 0 ]; then
                emit_error "unknown_command" "Unknown flag: $1"
            fi
            # After resource noun, pass through to subcommand
            ARGS+=("$1"); shift ;;
        *)
            ARGS+=("$1"); shift ;;
    esac
done

# Need at least a resource noun
if [ ${#ARGS[@]} -eq 0 ]; then
    emit_error "missing_argument" "Usage: zjctl <sessions|tabs|panes> <verb> [args...]"
fi

# Check we're in a zellij session (for commands that need it)
check_session() {
    if [ -z "${ZELLIJ_SESSION_NAME:-}" ] && [ -z "$ZJCTL_SESSION" ]; then
        emit_error "not_in_session" "Not in a zellij session. Set ZELLIJ_SESSION_NAME or use --session."
    fi
}

# =========================================================================
# Command implementations
# =========================================================================

# --- Sessions ---

cmd_sessions_list() {
    local raw
    raw=$(run_zellij list-sessions -n -s) || return $?

    local json
    json=$(echo "$raw" | jq -R . | jq -s '{sessions: [.[] | {name: .}]}')

    emit_output "$json" \
        "NAME" \
        '.sessions[] | [.name]'
}

# --- Tabs ---

cmd_tabs_list() {
    # Dry-run: show the primary zellij command and return
    if [ "$ZJCTL_DRY_RUN" = "true" ]; then
        run_zellij_action list-panes --json --all
        return 0
    fi

    local panes_json
    panes_json=$(run_zellij_action list-panes --json --all) || return $?

    local active_tab_json
    active_tab_json=$(run_zellij_action current-tab-info --json) || return $?
    local active_tab_id
    active_tab_id=$(echo "$active_tab_json" | jq -r '.tab_id')

    local json
    json=$(echo "$panes_json" | jq --argjson active_id "$active_tab_id" '
        [group_by(.tab_id)[] | {
            index: .[0].tab_position,
            name: .[0].tab_name,
            active: (.[0].tab_id == $active_id),
            tab_id: .[0].tab_id
        }] | sort_by(.index) | {tabs: .}
    ')

    emit_output "$json" \
        "INDEX\tNAME\tACTIVE\tTAB_ID" \
        '.tabs[] | [.index, .name, (if .active then "*" else "" end), .tab_id]'
}

cmd_tabs_focus() {
    if [ $# -eq 0 ]; then
        emit_error "missing_argument" "Usage: zjctl tabs focus <tab_name_or_index>"
    fi

    local target="$1"
    local index
    index=$(resolve_tab "$target")

    # zellij uses 1-based tab indexing
    local one_based=$((index + 1))
    if [ "$ZJCTL_DRY_RUN" = "true" ]; then
        run_zellij_action go-to-tab "$one_based"
        return 0
    fi
    run_zellij_action go-to-tab "$one_based" >/dev/null

    emit_action_result '{"ok": true}'
}

cmd_tabs_open() {
    local name="" layout=""
    local cmd_args=()
    local passthrough=false

    while [ $# -gt 0 ]; do
        if [ "$passthrough" = "true" ]; then
            cmd_args+=("$1"); shift; continue
        fi
        case "$1" in
            --name)  name="$2"; shift 2 ;;
            --layout) layout="$2"; shift 2 ;;
            --)      passthrough=true; shift ;;
            *)       emit_error "unknown_command" "Unknown tabs open flag: $1" ;;
        esac
    done

    local args=("new-tab")
    [ -n "$name" ] && args+=("--name" "$name")
    [ -n "$layout" ] && args+=("--layout" "$layout")
    if [ ${#cmd_args[@]} -gt 0 ]; then
        args+=("--")
        args+=("${cmd_args[@]}")
    fi

    local output
    output=$(run_zellij_action "${args[@]}") || return $?

    # new-tab doesn't reliably return the tab ID; re-query
    local panes_json
    panes_json=$(zellij action list-panes --json --all 2>/dev/null)
    local max_tab_id
    max_tab_id=$(echo "$panes_json" | jq '[.[].tab_id] | max')

    local json
    json=$(jq -n --argjson id "$max_tab_id" '{tab_id: $id}')
    emit_action_result "$json"
}

# --- Panes ---

cmd_panes_list() {
    local tab_filter=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --tab) tab_filter="$2"; shift 2 ;;
            *) emit_error "unknown_command" "Unknown panes list flag: $1" ;;
        esac
    done

    if [ "$ZJCTL_DRY_RUN" = "true" ]; then
        run_zellij_action list-panes --json --all
        return 0
    fi

    local panes_json
    panes_json=$(run_zellij_action list-panes --json --all) || return $?

    local filter_expr='.'
    if [ -n "$tab_filter" ]; then
        local tab_index
        tab_index=$(resolve_tab "$tab_filter")
        filter_expr="[.[] | select(.tab_position == $tab_index)]"
    fi

    local json
    json=$(echo "$panes_json" | jq "$filter_expr"' |
        [.[] | select(.is_selectable == true) | {
            id: (if .is_plugin then "plugin_\(.id)" else "terminal_\(.id)" end),
            command: (.pane_command // .terminal_command // null),
            cwd: (.pane_cwd // null),
            title: (if .title == "" then null else .title end),
            focused: .is_focused,
            floating: .is_floating,
            tab_id: .tab_id,
            tab_name: .tab_name
        }] | {panes: .}
    ')

    emit_output "$json" \
        "ID\tCOMMAND\tCWD\tTITLE\tFOCUSED\tFLOATING\tTAB" \
        '.panes[] | [.id, (.command // "-"), (.cwd // "-"), (.title // "-"), .focused, .floating, .tab_name]'
}

cmd_panes_read() {
    if [ $# -eq 0 ]; then
        emit_error "missing_argument" "Usage: zjctl panes read <pane> [--full] [--ansi]"
    fi

    local target="$1"; shift
    local full=false
    local ansi=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --full) full=true; shift ;;
            --ansi) ansi=true; shift ;;
            *) emit_error "unknown_command" "Unknown panes read flag: $1" ;;
        esac
    done

    local pane_id
    pane_id=$(resolve_pane "$target")

    local args=("dump-screen" "--pane-id" "$pane_id")
    [ "$full" = "true" ] && args+=("--full")
    [ "$ansi" = "true" ] && args+=("--ansi")

    if [ "$ZJCTL_DRY_RUN" = "true" ]; then
        run_zellij_action "${args[@]}"
        return 0
    fi

    local content
    content=$(run_zellij_action "${args[@]}") || return $?

    local json
    json=$(jq -n --arg id "$pane_id" --arg content "$content" '{pane_id: $id, content: $content}')

    emit_output "$json" \
        "PANE_ID\tCONTENT" \
        '[.pane_id, .content]'
}

cmd_panes_write() {
    if [ $# -lt 2 ]; then
        emit_error "missing_argument" "Usage: zjctl panes write <pane> <text>"
    fi

    local target="$1"
    local text="$2"

    local pane_id
    pane_id=$(resolve_pane "$target")

    check_self_write "$pane_id"

    if [ "$ZJCTL_DRY_RUN" = "true" ]; then
        run_zellij_action write-chars --pane-id "$pane_id" "$text"
        return 0
    fi
    run_zellij_action write-chars --pane-id "$pane_id" "$text" >/dev/null

    emit_action_result '{"ok": true}'
}

cmd_panes_send_keys() {
    if [ $# -lt 2 ]; then
        emit_error "missing_argument" "Usage: zjctl panes send-keys <pane> <keys...>"
    fi

    local target="$1"; shift
    local keys=("$@")

    local pane_id
    pane_id=$(resolve_pane "$target")

    check_self_write "$pane_id"

    if [ "$ZJCTL_DRY_RUN" = "true" ]; then
        run_zellij_action send-keys --pane-id "$pane_id" "${keys[@]}"
        return 0
    fi
    run_zellij_action send-keys --pane-id "$pane_id" "${keys[@]}" >/dev/null

    emit_action_result '{"ok": true}'
}

cmd_panes_focus() {
    if [ $# -eq 0 ]; then
        emit_error "missing_argument" "Usage: zjctl panes focus <pane>"
    fi

    local target="$1"
    local pane_id
    pane_id=$(resolve_pane "$target")

    if [ "$ZJCTL_DRY_RUN" = "true" ]; then
        run_zellij_action focus-pane-id "$pane_id"
        return 0
    fi
    run_zellij_action focus-pane-id "$pane_id" >/dev/null

    emit_action_result '{"ok": true}'
}

cmd_panes_open() {
    local direction="" floating=false name="" cwd="" tab_id=""
    local cmd_args=()
    local passthrough=false

    while [ $# -gt 0 ]; do
        if [ "$passthrough" = "true" ]; then
            cmd_args+=("$1"); shift; continue
        fi
        case "$1" in
            --direction) direction="$2"; shift 2 ;;
            --floating)  floating=true; shift ;;
            --name)      name="$2"; shift 2 ;;
            --cwd)       cwd="$2"; shift 2 ;;
            --tab-id)    tab_id="$2"; shift 2 ;;
            --)          passthrough=true; shift ;;
            *)           emit_error "unknown_command" "Unknown panes open flag: $1" ;;
        esac
    done

    local args=("new-pane")
    [ -n "$direction" ] && args+=("--direction" "$direction")
    [ "$floating" = "true" ] && args+=("--floating")
    [ -n "$name" ] && args+=("--name" "$name")
    [ -n "$cwd" ] && args+=("--cwd" "$cwd")
    [ -n "$tab_id" ] && args+=("--tab-id" "$tab_id")
    if [ ${#cmd_args[@]} -gt 0 ]; then
        args+=("--")
        args+=("${cmd_args[@]}")
    fi

    local output
    output=$(run_zellij_action "${args[@]}") || return $?

    # new-pane prints the pane ID (e.g., "terminal_12")
    local pane_id
    pane_id=$(echo "$output" | tr -d '[:space:]')

    local json
    json=$(jq -n --arg id "$pane_id" '{pane_id: $id}')
    emit_action_result "$json"
}

# =========================================================================
# Command routing
# =========================================================================

RESOURCE="${ARGS[0]}"
VERB="${ARGS[1]:-}"
# Remaining args after resource and verb
SUBARGS=()
if [ ${#ARGS[@]} -gt 2 ]; then
    SUBARGS=("${ARGS[@]:2}")
fi

case "$RESOURCE" in
    sessions)
        case "$VERB" in
            list)   cmd_sessions_list ;;
            "")     emit_error "missing_argument" "Usage: zjctl sessions list" ;;
            *)      emit_error "unknown_command" "Unknown sessions command: $VERB" ;;
        esac
        ;;
    tabs)
        check_session
        case "$VERB" in
            list)   cmd_tabs_list ;;
            focus)  cmd_tabs_focus ${SUBARGS[@]+"${SUBARGS[@]}"} ;;
            open)   cmd_tabs_open ${SUBARGS[@]+"${SUBARGS[@]}"} ;;
            "")     emit_error "missing_argument" "Usage: zjctl tabs <list|focus|open>" ;;
            *)      emit_error "unknown_command" "Unknown tabs command: $VERB" ;;
        esac
        ;;
    panes)
        check_session
        case "$VERB" in
            list)       cmd_panes_list ${SUBARGS[@]+"${SUBARGS[@]}"} ;;
            read)       cmd_panes_read ${SUBARGS[@]+"${SUBARGS[@]}"} ;;
            write)      cmd_panes_write ${SUBARGS[@]+"${SUBARGS[@]}"} ;;
            send-keys)  cmd_panes_send_keys ${SUBARGS[@]+"${SUBARGS[@]}"} ;;
            focus)      cmd_panes_focus ${SUBARGS[@]+"${SUBARGS[@]}"} ;;
            open)       cmd_panes_open ${SUBARGS[@]+"${SUBARGS[@]}"} ;;
            "")         emit_error "missing_argument" "Usage: zjctl panes <list|read|write|send-keys|focus|open>" ;;
            *)          emit_error "unknown_command" "Unknown panes command: $VERB" ;;
        esac
        ;;
    *)
        emit_error "unknown_command" "Unknown resource: $RESOURCE. Use sessions, tabs, or panes."
        ;;
esac
